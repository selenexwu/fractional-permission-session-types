type nat = +{zero : 1,
             succ : nat}

proc zero : . |- (n : nat) =
  n.zero;
  close n

proc succ[ni] : (n : <nat,*,ni>) |- (n1 : nat) =
  n1.succ;
  n1 <-> n

proc add[n1i,n2i] : (n1 : <nat,*,n1i>), (n2 : <nat,*,n2i>) |- (n : nat) =
  case n1 (
    zero =>
      wait n1;
      n <-> n2
  | succ =>
      n.succ;
      n <- add n1 n2
  )

type A = 1

type tree = /\k. &{
  ins: \\// !a. <A, *, a> -o tree,
  size: ?a. <nat, *, a> * \/ tree
}

proc leaf : . |- (t : tree) =
  immut { p =>
    case t (
      ins => mut {
        x <- recv t;
        t1 <- leaf;
        t2 <- leaf;
        t <- left_node x t1 t2
      }
    | size =>
        n <- zero;
        send t n;
        continue
    )
  }

proc left_node[xi,t1i,t2i] : (x : <A, *, xi>), (t1 : <tree, *, t1i>), (t2 : <tree, *, t2i>) |- (t : tree) =
  share t1; share t2;
  immut t1 t2 { p =>
    case t (
      ins => mut {
        own t1; own t2;
        y <- recv t;
        t1.ins;
        send t1 y;
        t <- right_node x t1 t2
      }
    | size =>
        t1.size;
        n1 <- recv t1;
        t2.size;
        n2 <- recv t2;
        s <- add n1 n2;
        s1 <- succ s;
        send t s1;
        continue t1 t2
    )
  }

proc right_node[xi,t1i,t2i] : (x : <A, *, xi>), (t1 : <tree, *, t1i>), (t2 : <tree, *, t2i>) |- (t : tree) =
  share t1; share t2;
  immut t1 t2 { p =>
    case t (
      ins => mut {
        own t1; own t2;
        y <- recv t;
        t2.ins;
        send t2 y;
        t <- left_node x t1 t2
      }
    | size =>
        t1.size;
        n1 <- recv t1;
        t2.size;
        n2 <- recv t2;
        s <- add n1 n2;
        s1 <- succ s;
        send t s1;
        continue t1 t2
    )
  }
