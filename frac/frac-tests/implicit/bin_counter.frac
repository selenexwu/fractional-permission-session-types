type bin = /\k. &{
  val: \\// mut_bin,
  dup: ?a. <bin, *, a> * \/ bin
}

type mut_bin = +{b0: mut_bin, b1: mut_bin, e: 1}

proc zero : . |- (b : bin) =
  immut { p =>
    case b (
      val => mut {
        b.e;
        close b
      }
    | dup =>
      b1 <- zero;
      send b b1;
      continue
    )
  }

proc one : . |- (b : bin) =
  immut { p =>
    case b (
      val => mut {
        b.b1;
        b.e;
        close b
      }
    | dup =>
      b1 <- one;
      send b b1;
      continue
    )
  }

proc add_mut[b0i,b1i] : (b0 : <mut_bin, *, b0i>), (b1 : <mut_bin, *, b1i>) |- (b : mut_bin) =
  case b0 (
    b0 =>
      case b1 (
        b0 =>
          b.b0;
          b <- add_mut b0 b1
      | b1 =>
          b.b1;
          b <- add_mut b0 b1
      | e =>
          wait b1;
          b.b0;
          b <-> b0
      )
  | b1 =>
      case b1 (
        b0 =>
          b.b1;
          b <- add_mut b0 b1
      | b1 =>
          b.b0;
          c <- one;
          c.val;
          b2 <- add_mut b1 c;
          b <- add_mut b0 b2
      | e =>
          wait b1;
          b.b1;
          b <-> b0
      )
  | e =>
      wait b0;
      b <-> b1
  )

proc add[b0i,b1i] : (b0 : <bin, *, b0i>), (b1 : <bin, *, b1i>) |- (b : bin) =
  immut b0 b1 { p =>
    case b (
      val => mut {
        b0.val;
        b1.val;
        b <- add_mut b0 b1
      }
    | dup =>
        b0.dup; b2 <- recv b0;
        b1.dup; b3 <- recv b1;
        s <- add b2 b3;
        send b s;
        continue b0 b1
    )
  }

type counter = /\k. &{
  inc: \\// counter,
  read: ?a. <bin, *, a> * \/ counter,
  done: \\// ?a. <bin, *, a> * 1
}

proc counter[bi] : (b : <bin, *, bi>) |- (c : counter) =
  immut b { p =>
    case c (
      inc => mut {
        one <- one;
        b1 <- add b one;
        c <- counter b1
      }
    | read =>
        b.dup;
        b1 <- recv b;
        send c b1;
        continue b
    | done => mut {
        send c b;
        close c
      }
    )
  }
