(* Natural Numbers *)

type nat = /\ k. &{
  val: \\// mut_nat,
  dup: ?a. <nat, *, a> * \/ nat
}

type mut_nat = +{zero: 1, succ: mut_nat}

proc zero : . |- (n : nat) =
  immut { p =>
    case n (
      val => mut {
        n.zero;
        close n
      }
    | dup =>
        n1 <- zero;
        send n n1;
        continue
    )
  }

proc succ[n0i] : (n0 : <nat, *, n0i>) |- (n : nat) =
  share n0;
  immut n0 { p =>
    case n (
      val => mut {
        own n0;
        n.succ;
        n0.val;
        n <-> n0
      }
    | dup =>
        n0.dup;
        n1 <- recv n0;
        n2 <- succ n1;
        send n n2;
        continue n0
    )
  }

proc drop_mut_nat[ni] : (n : <mut_nat, *, ni>) |- (d : 1) =
  case n (
    zero =>
      wait n;
      close d
  | succ =>
      d <- drop_mut_nat n
  )

proc drop_nat[ni] : (n : <nat, *, ni>) |- (d : 1) = n.val; d <- drop_mut_nat n

type bool = +{true: 1, false: 1}

proc lte[n1i,n2i] : (n1 : <mut_nat,*,n1i>), (n2 : <mut_nat,*,n2i>) |- (b : bool) =
  case n1 (
    zero =>
      wait n1;
      d <- drop_mut_nat n2; wait d;
      b.true; close b
  | succ =>
      case n2 (
        zero =>
          wait n2;
          d <- drop_mut_nat n1; wait d;
          b.false; close b
      | succ => b <- lte n1 n2
      )
  )

(* Auction and Buyer *)

type auction = /\k. +{
  running: ?max_bid. <nat, *, max_bid> * &{
    bid: \\// !id. <nat, *, id> -o !amount. <nat, *, amount> -o auction,
    ok: \/ auction
  },
  done: ?winner. <nat, *, winner> * \/ auction
}

type buyer = !auci. &{
  take: <auction, *, auci> -o <auction, *, auci> * buyer,
  view: !!p. <auction, p, auci> -o <auction, p, auci> * 1
}

proc running_auction[mbi,wi,nbi] : (max_bid : <nat,*,mbi>), (winner : <nat,*,wi>), (num_bids : <mut_nat,*,nbi>) |- (auc : auction) =
  case num_bids (
    zero =>
      wait num_bids;
      d <- drop_nat max_bid; wait d;
      auc <- done_auction winner
  | succ =>
      share max_bid; share winner;
      immut max_bid winner { p =>
        auc.running;
        max_bid.dup; mb1 <- recv max_bid;
        send auc mb1;
        case auc (
          bid => mut {
            own max_bid; own winner;
            id <- recv auc;
            amount <- recv auc;
            max_bid.dup; mb2 <- recv max_bid;
            mb2.val;
            amount.dup; am1 <- recv amount;
            am1.val;
            b <- lte am1 mb2;
            case b (
              true => (* bid too small *)
              wait b;
              d <- drop_nat amount; wait d;
              d1 <- drop_nat id; wait d1;
              auc <- running_auction max_bid winner num_bids
            | false => (* big large enough *)
              wait b;
              d <- drop_nat max_bid; wait d;
              d1 <- drop_nat winner; wait d1;
              auc <- running_auction amount id num_bids
            )
          }
        | ok => continue max_bid winner
        )
      }
  )

proc done_auction[wi] : (winner : <nat, *, wi>) |- (auc : auction) =
  share winner;
  immut winner { p =>
    auc.done;
    winner.dup; w1 <- recv winner;
    send auc w1;
    continue winner
  }

proc buyer[mbi,idi] : (max_bid : <nat, *, mbi>), (id : <nat, *, idi>) |- (buy : buyer) =
  {auci} <- recv buy;
  case buy (
    take =>
      auc <- recv buy;
      case auc (
        running =>
          current_bid <- recv auc;
          current_bid.dup; cb1 <- recv current_bid;
          max_bid.dup; mb1 <- recv max_bid;
          cb1.val;
          mb1.val;
          b <- lte mb1 cb1;
          case b (
            true => (* we're not going to bid *)
              wait b;
              auc.ok;
              send buy auc;
              d <- drop_nat current_bid; wait d;
              buy <- buyer max_bid id
          | false => (* we will bid one more than the current bid *)
              wait b;
              auc.bid;
              new_bid <- succ current_bid;
              id.dup; id1 <- recv id;
              send auc id1;
              send auc new_bid;

              send buy auc;
              buy <- buyer max_bid id
          )

      | done =>
          winner <- recv auc;
          (* yay, we know who won *)
          d <- drop_nat winner; wait d;

          send buy auc;
          buy <- buyer max_bid id
      )

  | view =>
      {{aucp}} <- recv buy;
      auc <- recv buy;
      (* view or something *)
      send buy auc;

      d <- drop_nat max_bid; wait d;
      d1 <- drop_nat id; wait d1;
      close buy
  )

(* Buyer Queue *)

type buyer_queue = &{
  ins : !a. <buyer,*,a> -o buyer_queue,
  del : +{none : 1, some : ?a. <buyer,*,a> * buyer_queue}
}

proc empty : . |- (q : buyer_queue) =
  case q (
    ins =>
      x <- recv q;
      e <- empty;
      q <- elem x e
  | del =>
      q.none;
      close q
  )

proc elem[xi,ti] : (x : <buyer,*,xi>), (t : <buyer_queue,*,ti>) |- (q : buyer_queue) =
  case q (
    ins =>
      y <- recv q;
      t.ins;
      send t y;
      q <- elem x t
  | del =>
      q.some;
      send q x;
      q <-> t
  )

(* Put it all together *)

proc all_take[auci,q1i,q2i] :
  (auc : <auction,*,auci>),
  (q1 : <buyer_queue,*,q1i>),
  (q2 : <buyer_queue,*,q2i>)
|- (res : <auction,*,auci> * <buyer_queue,*,q2i> * 1) =
  q1.del;
  case q1 (
    none =>
      wait q1;
      send res auc;
      send res q2;
      close res
  | some =>
      buyer <- recv q1;
      send buyer {auci};
      buyer.take;
      send buyer auc;
      auc <- recv buyer;
      q2.ins;
      send q2 buyer;
      res <- all_take auc q1 q2
  )

proc all_view[auci,qi]{aucp} :
  (auc : <auction,aucp,auci>),
  (q : <buyer_queue,*,qi>)
|- (res : <auction,aucp,auci> * 1) =
  q.del;
  case q (
    none =>
      wait q;
      send res auc;
      close res
  | some =>
      buyer <- recv q;
      auc1, auc2 <- split auc;
      rest <- all_view{0.5*aucp} auc1 q;
      send buyer {auci};
      buyer.view;
      send buyer {{0.5*aucp}}; send buyer auc2;
      auc2 <- recv buyer; wait buyer;
      auc1 <- recv rest; wait rest;
      auc <- merge auc1, auc2;
      send res auc;
      close res
  )

proc one : . |- (n1 : nat) =
  n0 <- zero;
  n1 <- succ n0

proc two : . |- (n2 : nat) =
  n0 <- zero;
  n1 <- succ n0;
  n2 <- succ n1

proc three : . |- (n3 : nat) =
  n0 <- zero;
  n1 <- succ n0;
  n2 <- succ n1;
  n3 <- succ n2

proc four : . |- (n4 : nat) =
  n0 <- zero;
  n1 <- succ n0;
  n2 <- succ n1;
  n3 <- succ n2;
  n4 <- succ n3

proc eight : . |- (n8 : nat) =
  n0 <- zero;
  n1 <- succ n0;
  n2 <- succ n1;
  n3 <- succ n2;
  n4 <- succ n3;
  n5 <- succ n4;
  n6 <- succ n5;
  n7 <- succ n6;
  n8 <- succ n7

proc main : . |- (res : 1) =
  max_bid1 <- two;
  id1 <- one;
  b1 <- buyer max_bid1 id1;

  max_bid2 <- three;
  id2 <- two;
  b2 <- buyer max_bid2 id2;

  max_bid3 <- one;
  id3 <- three;
  b3 <- buyer max_bid3 id3;

  max_bid4 <- one;
  id4 <- four;
  b4 <- buyer max_bid4 id4;

  z1 <- zero; z2 <- zero;
  num_bids <- eight; num_bids.val;
  auc <- running_auction z1 z2 num_bids;

  q1 <- empty;
  q2 <- elem b1 q1;
  q3 <- elem b2 q2;
  q4 <- elem b3 q3;
  q5 <- elem b4 q4;

  q6 <- empty;
  at1 <- all_take auc q5 q6;
  auc <- recv at1;
  q6 <- recv at1;

  q7 <- empty;
  at2 <- all_take auc q6 q7;
  auc <- recv at2;
  q7 <- recv at2;

  share auc;
  at3 <- all_view{1} auc q7;
  auc <- recv at3;
  own auc;

  abort (* no way to close an auction so we get stuck but that's whatever *)
