type nat = +{zero : 1,
             succ : nat}

proc zero : . |- (n : nat) =
  n.zero;
  close n

proc succ[ni] : (n : <nat,*,ni>) |- (n1 : nat) =
  n1.succ;
  n1 <-> n

type A = 1

type queue = /\k. &{ins : \\// !a. <A,*,a> -o queue,
                    del : \\// +{none : 1,
                                 some : ?a. <A,*,a> * queue},
                    len : ?a. <nat,*,a> * \/ queue}

proc empty : . |- (q : queue) =
  immut { p =>
    case q (
      ins => mut {
        x <- recv q;
        e <- empty;
        q <- elem x e
      }
    | del => mut {
        q.none;
        close q
      }
    | len =>
      n0 <- zero;
      send q n0;
      continue
    )
  }

proc elem[xi,ti] : (x : <A,*,xi>), (t : <queue,*,ti>) |- (q : queue) =
  immut t { p =>
    case q (
      ins => mut {
        y <- recv q;
        t.ins;
        send t y;
        q <- elem x t
      }
    | del => mut {
        q.some;
        send q x;
        q <-> t
      }
    | len =>
        t.len;
        n <- recv t;
        n1 <- succ n;
        send q n1;
        continue t
    )
  }

proc newA : . |- (a : A) = close a

proc main : . |- (out : queue) =
    q <- empty;
    e1 <- newA;
    q.ins;
    send q e1;
    q1, q2 <- split q;

    q1.len; q2.len;
    n1 <- recv q1;
    n2 <- recv q2;

    q <- merge q1, q2;
    e2 <- newA;
    q.ins;
    send q e2;
    abort
