(* Natural numbers *)
type nat = /\ k. &{
  val: \\// mut_nat,
  dup: ?a. <nat, *, a> * \/ nat
}

type mut_nat = +{zero: 1, succ: mut_nat}

proc zero : . |- (n : nat) =
  immut { p =>
    case n (
      val => mut {
        n.zero;
        close n
      }
    | dup =>
        n1 <- zero;
        send n n1;
        continue
    )
  }

proc succ[n0i] : (n0 : <nat, *, n0i>) |- (n : nat) =
  share n0;
  immut n0 { p =>
    case n (
      val => mut {
        own n0;
        n.succ;
        n0.val;
        n <-> n0
      }
    | dup =>
        n0.dup;
        n1 <- recv n0;
        n2 <- succ n1;
        send n n2;
        continue n0
    )
  }

proc drop_mut[ni] : (n : <mut_nat, *, ni>) |- (d : 1) =
  case n (
    zero =>
      wait n;
      close d
  | succ =>
      d <- drop_mut n
  )

proc drop[ni] : (n : <nat, *, ni>) |- (d : 1) = n.val; d <- drop_mut n

proc add_mut[n1i,n2i] : (n1 : <mut_nat,*,n1i>), (n2 : <mut_nat,*,n2i>) |- (n : mut_nat) =
  case n1 (
    zero =>
      wait n1;
      n <-> n2
  | succ =>
      n.succ;
      n <- add_mut n1 n2
  )


proc add[n1i,n2i] : (n1 : <nat,*,n1i>), (n2 : <nat,*,n2i>) |- (n : nat) =
  share n1; share n2;
  immut n1 n2 { p =>
    case n (
      val => mut {
        own n1; own n2;
        n1.val;
        n2.val;
        n <- add_mut n1 n2
      }
    | dup =>
        n1.dup; n3 <- recv n1;
        n2.dup; n4 <- recv n2;
        d <- add n3 n4;
        send n d;
        continue n1 n2
    )
  }

(* Workers *)

type work = 1
type result = 1

proc work : . |- (out : work) = close out
proc result : . |- (out : result) = close out

type worker = /\k. &{
  submit: \\// !in. <work, *, in> -o ?out. <result, *, out> * worker,
  count: ?a. <nat, *, a> * \/ worker
}

proc worker[ni] : (n : <nat, *, ni>) |- (out : worker) =
  share n;
  immut n { p =>
    case out (
      submit => mut {
        own n;
        work <- recv out;
        wait work;
        res <- result;
        send out res;
        n1 <- succ n;
        out <- worker n1
      }
    | count =>
        n.dup; n1 <- recv n;
        send out n1;
        continue n
    )
  }

(* Coordinator *)

proc partition_work[wi] : (w : <work,*,wi>) |- (out : ?w1i. <work,*,w1i> * ?w2i. <work,*,w2i> * ?w3i. <work,*,w3i> * 1) =
  w1 <- work;
  w2 <- work;
  send out w1;
  send out w2;
  send out w;
  close out

proc coordinator[k1i,k2i,k3i] :
  (k1 : <worker,*,k1i>),
  (k2 : <worker,*,k2i>),
  (k3 : <worker,*,k3i>)
|- (out : worker) =
  share k1; share k2; share k3;
  immut k1 k2 k3 { p =>
    case out (
      submit => mut {
        own k1; own k2; own k3;
        work <- recv out;
        sw <- partition_work work;
        w1 <- recv sw;
        w2 <- recv sw;
        w3 <- recv sw;
        wait sw;
        k1.submit;
        send k1 w1;
        k2.submit;
        send k2 w2;
        k3.submit;
        send k3 w3;
        r1 <- recv k1; wait r1;
        r2 <- recv k2; wait r2;
        r3 <- recv k3;
        send out r3;
        out <- coordinator k1 k2 k3
      }
    | count =>
        k1.count; n1 <- recv k1;
        k2.count; n2 <- recv k2;
        k3.count; n3 <- recv k3;
        ns1 <- add n1 n2;
        ns2 <- add ns1 n3;
        send out ns2;
        continue k1 k2 k3
    )
  }
