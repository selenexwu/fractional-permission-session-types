type nat = /\k. +{
  zero: \/ nat,
  succ: ?a. <nat, *, a> * \/ nat
}

proc zero : . |- (n : nat) =
  immut { p =>
    n.zero;
    continue
  }

proc succ[n0i] : (n0 : <nat, *, n0i>) |- (n : nat) =
  immut n0 { p =>
    n.succ;
    d <- dup{p} n0;
    n1 <- recv d;
    n0 <- recv d;
    wait d;
    send n n1;
    continue n0
  }

proc dup[n0i]{n0p} : (n0 : <nat, n0p, n0i>) |- (n : ?a. <nat, *, a> * <nat, n0p, n0i> * 1) =
  case n0 (
    zero =>
      n1 <- zero;
      send n n1;
      send n n0;
      close n
  | succ =>
      n1 <- recv n0;
      n2 <- succ n1;
      send n n2;
      send n n0;
      close n
  )
