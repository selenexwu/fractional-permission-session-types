(* Natural numbers *)
type nat = /\ k. &{
  val: \\// mut_nat,
  dup: ?a. <nat, *, a> * \/ nat
}

type mut_nat = +{zero: 1, succ: mut_nat}

proc zero : . |- (n : nat) =
  immut { p =>
    case n (
      val => mut {
        n.zero;
        close n
      }
    | dup =>
        {n1i}, n1 <- zero;
        send n {n1i};
        send n n1;
        continue
    )
  }

proc succ[n0i] : (n0 : <nat, *, n0i>) |- (n : nat) =
  share n0;
  immut n0 { p =>
    case n (
      val => mut {
        own n0;
        n.succ;
        start n0{*}; n0.val; mutate n0;
        n <-> n0
      }
    | dup =>
        start n0{p};
        n0.dup;
        {n1i} <- recv n0;
        n1 <- recv n0;
        finish n0;
        {n2i}, n2 <- succ[n1i] n1;
        send n {n2i};
        send n n2;
        continue n0
    )
  }

proc drop_mut[ni] : (n : <mut_nat, *, ni>) |- (d : 1) =
  case n (
    zero =>
      wait n;
      close d
  | succ =>
      d <- drop_mut[ni] n
  )

proc drop[ni] : (n : <nat, *, ni>) |- (d : 1) = start n{*}; n.val; mutate n; d <- drop_mut[ni] n

proc add_mut[n1i,n2i] : (n1 : <mut_nat,*,n1i>), (n2 : <mut_nat,*,n2i>) |- (n : mut_nat) =
  case n1 (
    zero =>
      wait n1;
      n <-> n2
  | succ =>
      n.succ;
      n <- add_mut[n1i,n2i] n1 n2
  )


proc add[n1i,n2i] : (n1 : <nat,*,n1i>), (n2 : <nat,*,n2i>) |- (n : nat) =
  share n1; share n2;
  immut n1 n2 { p =>
    case n (
      val => mut {
        own n1; own n2;
        start n1{*}; n1.val; mutate n1;
        start n2{*}; n2.val; mutate n2;
        n <- add_mut[n1i,n2i] n1 n2
      }
    | dup =>
        start n1{p}; n1.dup; {n3i} <- recv n1; n3 <- recv n1; finish n1;
        start n2{p}; n2.dup; {n4i} <- recv n2; n4 <- recv n2; finish n2;
        {di}, d <- add[n3i,n4i] n3 n4;
        send n {di}; send n d;
        continue n1 n2
    )
  }

(* Workers *)

type work = 1
type result = 1

proc work : . |- (out : work) = close out
proc result : . |- (out : result) = close out

type worker = /\k. &{
  submit: \\// !in. <work, *, in> -o ?out. <result, *, out> * worker,
  count: ?a. <nat, *, a> * \/ worker
}

proc worker[ni] : (n : <nat, *, ni>) |- (out : worker) =
  share n;
  immut n { p =>
    case out (
      submit => mut {
        own n;
        {wi} <- recv out; work <- recv out;
        wait work;
        {ri}, res <- result;
        send out {ri}; send out res;
        {n1i}, n1 <- succ[ni] n;
        out <- worker[n1i] n1
      }
    | count =>
        start n{p}; n.dup; {n1i} <- recv n; n1 <- recv n; finish n;
        send out {n1i}; send out n1;
        continue n
    )
  }

(* Coordinator *)

proc partition_work[wi] : (w : <work,*,wi>) |- (out : ?w1i. <work,*,w1i> * ?w2i. <work,*,w2i> * ?w3i. <work,*,w3i> * 1) =
  {w1i}, w1 <- work;
  {w2i}, w2 <- work;
  send out {w1i}; send out w1;
  send out {w2i}; send out w2;
  send out {wi}; send out w;
  close out

proc coordinator[k1i,k2i,k3i] :
  (k1 : <worker,*,k1i>),
  (k2 : <worker,*,k2i>),
  (k3 : <worker,*,k3i>)
|- (out : worker) =
  share k1; share k2; share k3;
  immut k1 k2 k3 { p =>
    case out (
      submit => mut {
        own k1; own k2; own k3;
        {wi} <- recv out; work <- recv out;
        {swi}, sw <- partition_work[wi] work;
        {w1i} <- recv sw; w1 <- recv sw;
        {w2i} <- recv sw; w2 <- recv sw;
        {w3i} <- recv sw; w3 <- recv sw;
        wait sw;
        start k1{*}; k1.submit; mutate k1;
        send k1 {w1i}; send k1 w1;
        start k2{*}; k2.submit; mutate k2;
        send k2 {w2i}; send k2 w2;
        start k3{*}; k3.submit; mutate k3;
        send k3 {w3i}; send k3 w3;
        {r1i} <- recv k1; r1 <- recv k1; wait r1;
        {r2i} <- recv k2; r2 <- recv k2; wait r2;
        {r3i} <- recv k3; r3 <- recv k3;
        send out {r3i}; send out r3;
        out <- coordinator[k1i,k2i,k3i] k1 k2 k3
      }
    | count =>
        start k1{p}; k1.count; {n1i} <- recv k1; n1 <- recv k1; finish k1;
        start k2{p}; k2.count; {n2i} <- recv k2; n2 <- recv k2; finish k2;
        start k3{p}; k3.count; {n3i} <- recv k3; n3 <- recv k3; finish k3;
        {ns1i}, ns1 <- add[n1i,n2i] n1 n2;
        {ns2i}, ns2 <- add[ns1i,n3i] ns1 n3;
        send out {ns2i}; send out ns2;
        continue k1 k2 k3
    )
  }
